---
import Layout from "../../layouts/Layout.astro";
import WelcomeBackground from "@/components/welcome-background.tsx";
import MobileSidebar from "@/components/MobileSidebar.astro";
import HeroCard from "@/components/HeroCard.astro";
import BlogList from "@/components/BlogList.astro";
import * as CVMarkdown from './cv.mdx'
---

<Layout>
    <div class="relative h-screen w-full" transition:name="bg-container" transition:animate="none">
        <WelcomeBackground client:load transition:persist="bg" />

        <div class="z-10 absolute inset-0 grid grid-cols-1 grid-rows-[1fr] md:grid-cols-[auto_1fr] md:grid-rows-2 gap-4 p-6 pt-16 md:pt-6">
            <!-- Sidebar: drawer on mobile, grid children on desktop -->
            <MobileSidebar>
                <div class="md:row-start-1 md:col-start-1 md:row-span-1 md:self-start">
                    <HeroCard />
                </div>
                <div class="md:row-start-2 md:col-start-1 md:row-span-1 md:self-stretch">
                    <BlogList compact/>
                </div>
            </MobileSidebar>

            <!-- Post content — full width on mobile, right side on desktop -->
            <div transition:name="post-content" id="cv" class="md:row-start-1 md:col-start-2 md:row-span-2 overflow-y-auto bg-slate-900/90 p-8 rounded-lg min-h-0">
                <h1 class="text-4xl">CV</h1>
                <CVMarkdown.Content />
            </div>
        </div>
    </div>
</Layout>

<style>
    #cv {
        font-family: "EB Garamond Variable";
    }
</style>