---
import Layout from "../../layouts/Layout.astro";
import WelcomeBackground from "@/components/welcome-background.tsx";
import MobileSidebar from "@/components/MobileSidebar.astro";
import HeroCard from "@/components/HeroCard.astro";
import BlogList from "@/components/BlogList.astro";
import * as CVMarkdown from './cv.mdx'
---

<Layout>
    <div class="cv-container" transition:name="bg-container" transition:animate="none">
        <WelcomeBackground client:load transition:persist="bg" />

        <div class="cv-layout">
            <!-- Sidebar: drawer on mobile, grid children on desktop -->
            <MobileSidebar>
                <div class="cv-hero">
                    <HeroCard />
                </div>
                <div class="cv-bloglist">
                    <BlogList compact/>
                </div>
            </MobileSidebar>

            <!-- Post content — full width on mobile, right side on desktop -->
            <div transition:name="post-content" id="cv" class="cv-content">
                <h1>CV</h1>
                <CVMarkdown.Content />
            </div>
        </div>
    </div>
</Layout>

<style>
	.cv-container {
		position: relative;
		height: 100vh;
		width: 100%;
	}
	
	.cv-layout {
		z-index: 10;
		position: absolute;
		inset: 0;
		display: grid;
		grid-template-columns: 1fr;
		grid-template-rows: 1fr;
		gap: 1rem;
		padding: 1.5rem;
		padding-top: 4rem;
	}
	
	.cv-hero {
		display: block;
	}
	
	.cv-bloglist {
		display: block;
	}
	
	.cv-content {
		overflow-y: auto;
		background-color: rgba(15, 23, 42, 0.9);
		padding: 2rem;
		border-radius: 0.5rem;
		min-height: 0;
	}
	
	.cv-content h1 {
		font-size: 2.25rem;
		line-height: 2.5rem;
	}
	
	#cv {
		font-family: "EB Garamond Variable";
	}
	
	@media (min-width: 768px) {
		.cv-layout {
			grid-template-columns: auto 1fr;
			grid-template-rows: auto 1fr;
			padding-top: 1.5rem;
		}
		
		.cv-hero {
			grid-row-start: 1;
			grid-column-start: 1;
			grid-row: span 1;
			align-self: start;
		}
		
		.cv-bloglist {
			grid-row-start: 2;
			grid-column-start: 1;
			grid-row: span 1;
			align-self: stretch;
		}
		
		.cv-content {
			grid-row-start: 1;
			grid-column-start: 2;
			grid-row: span 2;
		}
	}
</style>